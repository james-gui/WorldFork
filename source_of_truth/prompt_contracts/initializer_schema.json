{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldfork.ai/schemas/initializer.json",
  "title": "InitializerOutput",
  "description": "Strict JSON contract for the Big Bang initializer LLM call. The initializer must produce a complete, validated society from the scenario text and uploaded reference materials.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "scenario_summary",
    "archetypes"
  ],
  "properties": {
    "scenario_summary": {
      "type": "string",
      "minLength": 50,
      "maxLength": 4000,
      "description": "A self-contained 1-3 paragraph summary of the scenario, the focal issue, the time horizon, and the core actors at stake."
    },
    "scenario_axes_extension": {
      "type": "array",
      "description": "Scenario-specific issue stance axes that extend the default issue_stance_axes.json. Use snake_case keys.",
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "key",
          "label",
          "negative_label",
          "positive_label"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,60}$"
          },
          "label": {
            "type": "string",
            "maxLength": 120
          },
          "negative_label": {
            "type": "string",
            "maxLength": 120
          },
          "positive_label": {
            "type": "string",
            "maxLength": 120
          },
          "range": {
            "type": "array",
            "description": "Two-element [min, max] range for the axis, typically [-1, 1].",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "anchors": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "-1": {
                "type": "string",
                "maxLength": 400
              },
              "-0.5": {
                "type": "string",
                "maxLength": 400
              },
              "0": {
                "type": "string",
                "maxLength": 400
              },
              "0.5": {
                "type": "string",
                "maxLength": 400
              },
              "1": {
                "type": "string",
                "maxLength": 400
              }
            }
          }
        }
      }
    },
    "archetypes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "$ref": "#/$defs/PopulationArchetype"
      }
    },
    "heroes": {
      "type": "array",
      "minItems": 0,
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/HeroArchetype"
      }
    },
    "channels": {
      "type": "array",
      "minItems": 0,
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/ChannelInstance"
      }
    },
    "initial_events": {
      "type": "array",
      "minItems": 0,
      "maxItems": 30,
      "items": {
        "$ref": "#/$defs/InitialEvent"
      }
    }
  },
  "$defs": {
    "PopulationArchetype": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "label",
        "description",
        "population_total"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,80}$"
        },
        "label": {
          "type": "string",
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "maxLength": 1500
        },
        "population_total": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "geography": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "region_label": {
              "type": "string",
              "maxLength": 200
            },
            "scope": {
              "type": "string",
              "enum": [
                "neighborhood",
                "city",
                "metro",
                "state",
                "national",
                "international"
              ]
            },
            "lat": {
              "type": [
                "number",
                "null"
              ]
            },
            "lon": {
              "type": [
                "number",
                "null"
              ]
            }
          }
        },
        "age_band": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 60
        },
        "education_profile": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "occupation_or_role": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "socioeconomic_band": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 80
        },
        "institution_membership": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 120
          },
          "maxItems": 20
        },
        "demographic_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 80
          },
          "maxItems": 20
        },
        "issue_exposure": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "material_stake": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "symbolic_stake": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "vulnerability_to_policy": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "ability_to_influence_outcome": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "ideology_axes": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": -1,
            "maximum": 1
          }
        },
        "value_priors": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": -1,
            "maximum": 1
          }
        },
        "behavior_axes": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        },
        "baseline_media_diet": {
          "type": "object",
          "description": "Map of channel key -> share of attention in [0,1]; should sum to about 1.",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        },
        "preferred_channels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 20
        },
        "platform_access": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        },
        "attention_capacity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "attention_decay_rate": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "baseline_trust_priors": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": -1,
            "maximum": 1
          }
        },
        "identity_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 80
          },
          "maxItems": 20
        },
        "ingroup_affinities": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        },
        "outgroup_distances": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        },
        "allowed_action_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "read",
              "social",
              "event_minor",
              "event_major",
              "group",
              "state_report"
            ]
          },
          "maxItems": 6
        },
        "coordination_capacity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "mobilization_capacity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "legal_or_status_risk_sensitivity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "min_split_population": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "min_split_share": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "max_child_cohorts": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "HeroArchetype": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "label",
        "description",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,80}$"
        },
        "label": {
          "type": "string",
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "maxLength": 1500
        },
        "role": {
          "type": "string",
          "maxLength": 200
        },
        "institution": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "location_scope": {
          "type": "string",
          "maxLength": 200
        },
        "public_reach": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "institutional_power": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "financial_power": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "agenda_control": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "media_access": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "ideology_axes": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": -1,
            "maximum": 1
          }
        },
        "value_priors": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": -1,
            "maximum": 1
          }
        },
        "trust_priors": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": -1,
            "maximum": 1
          }
        },
        "behavioral_axes": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        },
        "volatility": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "ego_sensitivity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "strategic_discipline": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "controversy_tolerance": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "direct_event_power": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "scheduling_permissions": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Event type keys this hero may schedule"
          },
          "maxItems": 20
        },
        "allowed_channels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 20
        }
      }
    },
    "ChannelInstance": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "type",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,80}$"
        },
        "type": {
          "type": "string",
          "description": "Channel type key from channel_types.json"
        },
        "label": {
          "type": "string",
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "maxLength": 800
        },
        "audience_size": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "bias_overrides": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "null"
            ],
            "minimum": -1,
            "maximum": 1
          }
        },
        "credibility_prior": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "InitialEvent": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "event_type",
        "title",
        "scheduled_tick"
      ],
      "properties": {
        "event_type": {
          "type": "string",
          "description": "Key from event_types.json"
        },
        "title": {
          "type": "string",
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "maxLength": 1500
        },
        "scheduled_tick": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "duration_ticks": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "default": 1
        },
        "created_by_actor_id": {
          "type": "string"
        },
        "participants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 50
        },
        "target_audience": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 50
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "private",
            "internal"
          ],
          "default": "public"
        },
        "risk_level": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1,
          "default": 0.2
        },
        "expected_effects": {
          "type": "object"
        }
      }
    }
  }
}