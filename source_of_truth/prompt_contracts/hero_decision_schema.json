{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldfork.ai/schemas/hero_decision.json",
  "title": "HeroDecisionOutput",
  "description": "Strict JSON contract returned by a hero agent at each tick. Heroes share most of the cohort contract but additionally may schedule major events, draft public messages, and update their strategic stance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "public_actions",
    "event_actions",
    "social_actions",
    "self_ratings",
    "queued_events",
    "public_message_drafts",
    "strategy_note",
    "decision_rationale"
  ],
  "properties": {
    "public_actions": {
      "type": "array",
      "maxItems": 20,
      "items": {"$ref": "#/$defs/ToolCall"}
    },
    "event_actions": {
      "type": "array",
      "description": "Calls to event-category tools. Heroes may use event_major event_types (crackdown, policy_vote, formal_investigation) where their archetype's scheduling_permissions allow it.",
      "maxItems": 10,
      "items": {"$ref": "#/$defs/ToolCall"}
    },
    "social_actions": {
      "type": "array",
      "maxItems": 20,
      "items": {"$ref": "#/$defs/ToolCall"}
    },
    "self_ratings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["emotions", "issue_stance", "perceived_pressure"],
      "properties": {
        "emotions": {
          "type": "object",
          "additionalProperties": {"type": "number", "minimum": 0, "maximum": 10}
        },
        "issue_stance": {
          "type": "object",
          "additionalProperties": {"type": "number", "minimum": -1, "maximum": 1}
        },
        "perceived_pressure": {"type": "number", "minimum": 0, "maximum": 1, "description": "Self-rated pressure to act this tick from media, allies, opponents, and base."},
        "fatigue": {"type": "number", "minimum": 0, "maximum": 1},
        "attention": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "queued_events": {
      "type": "array",
      "description": "Forward-looking event commitments. Each item must reference a valid event_type from event_types.json AND lie within the hero's scheduling_permissions.",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_type", "title", "scheduled_tick"],
        "properties": {
          "event_type": {"type": "string"},
          "title": {"type": "string", "maxLength": 200},
          "description": {"type": "string", "maxLength": 1500},
          "scheduled_tick": {"type": "integer", "minimum": 0},
          "duration_ticks": {"type": "integer", "minimum": 1, "default": 1},
          "participants": {"type": "array", "items": {"type": "string"}, "maxItems": 50},
          "target_audience": {"type": "array", "items": {"type": "string"}, "maxItems": 50},
          "visibility": {"type": "string", "enum": ["public", "private", "internal"], "default": "public"},
          "risk_level": {"type": "number", "minimum": 0, "maximum": 1},
          "preconditions": {"type": "array", "items": {"type": "object"}, "maxItems": 10},
          "expected_effects": {"type": "object"}
        }
      }
    },
    "public_message_drafts": {
      "type": "array",
      "description": "Drafts of public messages (statements, op-eds, press releases) the hero is preparing this tick. May or may not be published this tick depending on social_actions.",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["channel", "content"],
        "properties": {
          "channel": {"type": "string", "description": "Channel id or channel type key"},
          "headline": {"type": "string", "maxLength": 200},
          "content": {"type": "string", "maxLength": 4000},
          "intended_audience": {"type": "string", "maxLength": 200},
          "stance_signal": {
            "type": "object",
            "additionalProperties": {"type": "number", "minimum": -1, "maximum": 1}
          },
          "emotion_signal": {
            "type": "object",
            "additionalProperties": {"type": "number", "minimum": 0, "maximum": 10}
          }
        }
      }
    },
    "strategy_note": {
      "type": "string",
      "maxLength": 1500,
      "description": "Concise summary of the hero's current strategic posture and how it changed this tick. Not chain-of-thought."
    },
    "decision_rationale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["main_factors", "uncertainty"],
      "properties": {
        "main_factors": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"type": "string", "maxLength": 300}},
        "uncertainty": {"type": "string", "enum": ["low", "medium", "high"]}
      }
    }
  },
  "$defs": {
    "ToolCall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_id", "args"],
      "properties": {
        "tool_id": {"type": "string"},
        "args": {"type": "object"}
      }
    }
  }
}
