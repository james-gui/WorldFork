{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldfork.ai/schemas/god_review.json",
  "title": "GodReviewOutput",
  "description": "Strict JSON contract returned by the god-agent after each universe tick (PRD §13.6). The god-agent must NOT rewrite parent history; any divergence is expressed as a branch_delta on a new child universe.",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "marked_key_events", "tick_summary", "rationale"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["continue", "freeze", "kill", "spawn_candidate", "spawn_active"],
      "description": "Top-level disposition for the reviewed universe."
    },
    "branch_delta": {
      "description": "Required when decision is spawn_candidate or spawn_active; must be null for continue/freeze/kill.",
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {"type": "string", "enum": ["counterfactual_event_rewrite", "parameter_shift", "actor_state_override", "hero_decision_override"]},
            "rationale": {"type": "string", "maxLength": 1500},
            "target_event_id": {"type": "string"},
            "parent_version": {"type": "string", "maxLength": 1000},
            "child_version": {"type": "string", "maxLength": 1000},
            "target": {"type": "string"},
            "delta": {"type": "object"},
            "actor_id": {"type": "string"},
            "field": {"type": "string"},
            "value": {},
            "hero_id": {"type": "string"},
            "decision_override": {"type": "object"}
          },
          "allOf": [
            {
              "if": {"properties": {"type": {"const": "counterfactual_event_rewrite"}}, "required": ["type"]},
              "then": {"required": ["target_event_id", "parent_version", "child_version"]}
            },
            {
              "if": {"properties": {"type": {"const": "parameter_shift"}}, "required": ["type"]},
              "then": {"required": ["target", "delta"]}
            },
            {
              "if": {"properties": {"type": {"const": "actor_state_override"}}, "required": ["type"]},
              "then": {"required": ["actor_id", "field", "value"]}
            },
            {
              "if": {"properties": {"type": {"const": "hero_decision_override"}}, "required": ["type"]},
              "then": {"required": ["hero_id", "decision_override"]}
            }
          ]
        }
      ]
    },
    "marked_key_events": {
      "type": "array",
      "maxItems": 20,
      "items": {"type": "string", "description": "event_id values from the tick that should be flagged as key narrative beats."}
    },
    "tick_summary": {
      "type": "string",
      "minLength": 30,
      "maxLength": 2000,
      "description": "1-3 sentence narrative summary of what happened this tick and why the chosen disposition fits."
    },
    "rationale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["main_factors", "confidence"],
      "properties": {
        "main_factors": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {"type": "string", "maxLength": 400},
          "description": "Concise structured list of the dominant factors in the disposition decision. Not chain-of-thought."
        },
        "confidence": {"type": "string", "enum": ["low", "medium", "high"]}
      }
    },
    "divergence_score_estimate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Optional self-reported estimate of how much the proposed branch would diverge from the parent. Branch policy uses min_divergence_score."
    },
    "estimated_branch_value": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Optional self-reported value/insight estimate for the proposed branch (used by branch_policy when capacity is constrained)."
    }
  }
}
