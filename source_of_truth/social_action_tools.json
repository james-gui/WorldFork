{
  "version": "1.0.0",
  "note": "Complete tool registry per PRD §10.4. Each tool exposes a JSONSchema (Draft 2020-12) suitable for OpenAI-style tool calling. Closed schemas use additionalProperties:false. The engine validates LLM tool-call args against these schemas before commit.",
  "tools": [
    {
      "tool_id": "read_visible_feed",
      "category": "read",
      "description": "Read the social-media feed currently visible to the calling actor. Returns posts only from channels the actor has access to.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "max_items": {"type": "integer", "minimum": 1, "maximum": 100, "default": 25},
          "since_tick": {"type": "integer", "minimum": 0}
        }
      }
    },
    {
      "tool_id": "read_visible_events",
      "category": "read",
      "description": "Read events currently visible to the calling actor (active events plus scheduled events the actor can see).",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "include_scheduled": {"type": "boolean", "default": true},
          "include_completed": {"type": "boolean", "default": false},
          "max_items": {"type": "integer", "minimum": 1, "maximum": 50, "default": 20}
        }
      }
    },
    {
      "tool_id": "read_own_queued_events",
      "category": "read",
      "description": "Read events the calling actor has queued but not yet executed.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      }
    },
    {
      "tool_id": "read_own_recent_actions",
      "category": "read",
      "description": "Read the calling actor's own recent actions (posts, comments, votes, queued events) in the last N ticks.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "lookback_ticks": {"type": "integer", "minimum": 1, "maximum": 20, "default": 5}
        }
      }
    },
    {
      "tool_id": "read_retrieved_memory",
      "category": "read",
      "description": "Read a Zep/local memory summary for the calling actor relevant to the current tick context.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "query": {"type": "string", "maxLength": 500},
          "max_episodes": {"type": "integer", "minimum": 1, "maximum": 20, "default": 5}
        }
      }
    },
    {
      "tool_id": "create_social_post",
      "category": "social",
      "description": "Publish a public post on a platform channel.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["platform", "content"],
        "properties": {
          "platform": {"type": "string", "description": "Channel key from channel_types.json"},
          "content": {"type": "string", "maxLength": 2000},
          "visibility_scope": {"type": "string", "enum": ["public", "followers", "private_group"], "default": "public"},
          "stance_signal": {
            "type": "object",
            "description": "Map of stance_axis_key -> value in [-1, 1]",
            "additionalProperties": {"type": "number", "minimum": -1, "maximum": 1}
          },
          "emotion_signal": {
            "type": "object",
            "description": "Map of emotion_key -> value in [0, 10]",
            "additionalProperties": {"type": "number", "minimum": 0, "maximum": 10}
          },
          "credibility_signal": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    {
      "tool_id": "comment_on_post",
      "category": "social",
      "description": "Reply to an existing post visible to the calling actor.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["post_id", "content"],
        "properties": {
          "post_id": {"type": "string"},
          "content": {"type": "string", "maxLength": 1000},
          "stance_signal": {"type": "object", "additionalProperties": {"type": "number", "minimum": -1, "maximum": 1}},
          "emotion_signal": {"type": "object", "additionalProperties": {"type": "number", "minimum": 0, "maximum": 10}}
        }
      }
    },
    {
      "tool_id": "repost",
      "category": "social",
      "description": "Repost an existing post to the calling actor's audience, optionally with a quoted comment.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["post_id"],
        "properties": {
          "post_id": {"type": "string"},
          "quote_comment": {"type": "string", "maxLength": 500}
        }
      }
    },
    {
      "tool_id": "upvote_or_promote",
      "category": "social",
      "description": "Cast an upvote / promotional reaction on a post, increasing its hot score.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["post_id"],
        "properties": {
          "post_id": {"type": "string"},
          "reaction": {"type": "string", "enum": ["upvote", "like", "boost"], "default": "upvote"}
        }
      }
    },
    {
      "tool_id": "downvote_or_criticize",
      "category": "social",
      "description": "Cast a downvote or critical reaction on a post.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["post_id"],
        "properties": {
          "post_id": {"type": "string"},
          "reaction": {"type": "string", "enum": ["downvote", "dislike", "report"], "default": "downvote"}
        }
      }
    },
    {
      "tool_id": "follow_actor",
      "category": "social",
      "description": "Add an actor to the calling actor's followed list (raises future exposure to that actor's posts).",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actor_id"],
        "properties": {
          "actor_id": {"type": "string"}
        }
      }
    },
    {
      "tool_id": "unfollow_actor",
      "category": "social",
      "description": "Remove an actor from the calling actor's followed list.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actor_id"],
        "properties": {
          "actor_id": {"type": "string"}
        }
      }
    },
    {
      "tool_id": "stay_silent",
      "category": "social",
      "description": "Explicitly elect not to post or react this tick. Reported as a decision so the engine can distinguish silence-by-choice from silence-by-fatigue.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "reason": {"type": "string", "enum": ["spiral_of_silence", "fatigue", "strategic_wait", "no_signal", "other"], "default": "no_signal"},
          "note": {"type": "string", "maxLength": 300}
        }
      }
    },
    {
      "tool_id": "queue_event",
      "category": "event",
      "description": "Schedule a future event of a known event_type to occur at a specific tick. Validators reject unknown event_types and reject scheduling beyond max_schedule_horizon_ticks.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_type", "title", "scheduled_tick"],
        "properties": {
          "event_type": {"type": "string", "description": "Key from event_types.json"},
          "title": {"type": "string", "maxLength": 200},
          "description": {"type": "string", "maxLength": 1000},
          "scheduled_tick": {"type": "integer", "minimum": 0},
          "duration_ticks": {"type": "integer", "minimum": 1, "default": 1},
          "participants": {"type": "array", "items": {"type": "string"}, "maxItems": 50},
          "target_audience": {"type": "array", "items": {"type": "string"}, "maxItems": 50},
          "visibility": {"type": "string", "enum": ["public", "private", "internal"], "default": "public"},
          "preconditions": {"type": "array", "items": {"type": "object"}, "maxItems": 10},
          "expected_effects": {"type": "object"},
          "risk_level": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    {
      "tool_id": "modify_own_queued_event",
      "category": "event",
      "description": "Modify an event the calling actor previously queued (and which has not yet started).",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id"],
        "properties": {
          "event_id": {"type": "string"},
          "title": {"type": "string", "maxLength": 200},
          "description": {"type": "string", "maxLength": 1000},
          "scheduled_tick": {"type": "integer", "minimum": 0},
          "duration_ticks": {"type": "integer", "minimum": 1},
          "participants": {"type": "array", "items": {"type": "string"}, "maxItems": 50},
          "visibility": {"type": "string", "enum": ["public", "private", "internal"]},
          "risk_level": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    {
      "tool_id": "cancel_own_queued_event",
      "category": "event",
      "description": "Cancel an event previously queued by the calling actor.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id"],
        "properties": {
          "event_id": {"type": "string"},
          "reason": {"type": "string", "maxLength": 500}
        }
      }
    },
    {
      "tool_id": "support_event",
      "category": "event",
      "description": "Publicly endorse an existing event (raises participation prior, moves expression and mobilization).",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id"],
        "properties": {
          "event_id": {"type": "string"},
          "support_intensity": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.5},
          "public_statement": {"type": "string", "maxLength": 500}
        }
      }
    },
    {
      "tool_id": "oppose_event",
      "category": "event",
      "description": "Publicly oppose an existing event.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id"],
        "properties": {
          "event_id": {"type": "string"},
          "oppose_intensity": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.5},
          "public_statement": {"type": "string", "maxLength": 500}
        }
      }
    },
    {
      "tool_id": "propose_split",
      "category": "group",
      "description": "Propose a split of the calling cohort into two or more child cohorts. Engine validates min_split_share, min_split_population, split_distance_threshold, child population sums == parent, max_child_cohorts.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["proposed_children", "rationale"],
        "properties": {
          "rationale": {"type": "string", "maxLength": 800},
          "proposed_children": {
            "type": "array",
            "minItems": 2,
            "maxItems": 4,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["population_share", "differentiator"],
              "properties": {
                "label_hint": {"type": "string", "maxLength": 80},
                "population_share": {"type": "number", "minimum": 0, "maximum": 1},
                "differentiator": {"type": "string", "maxLength": 400, "description": "What distinguishes this child from siblings (stance, expression, trust)."},
                "issue_stance_delta": {"type": "object", "additionalProperties": {"type": "number", "minimum": -1, "maximum": 1}},
                "expression_level_hint": {"type": "number", "minimum": 0, "maximum": 1},
                "emotion_delta": {"type": "object", "additionalProperties": {"type": "number", "minimum": -10, "maximum": 10}}
              }
            }
          }
        }
      }
    },
    {
      "tool_id": "propose_merge",
      "category": "group",
      "description": "Propose merging the calling cohort with one or more sibling cohorts in the same archetype. Engine validates similarity and low-divergence-ticks conditions.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_cohort_ids", "rationale"],
        "properties": {
          "target_cohort_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 4},
          "rationale": {"type": "string", "maxLength": 800}
        }
      }
    },
    {
      "tool_id": "propose_create_coalition",
      "category": "group",
      "description": "Propose forming a named coalition with one or more other cohorts/heroes around a stated purpose.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["coalition_label", "members", "purpose"],
        "properties": {
          "coalition_label": {"type": "string", "maxLength": 120},
          "members": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 30},
          "purpose": {"type": "string", "maxLength": 600},
          "expected_duration_ticks": {"type": "integer", "minimum": 1}
        }
      }
    },
    {
      "tool_id": "propose_join_coalition",
      "category": "group",
      "description": "Propose joining an existing coalition.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["coalition_id"],
        "properties": {
          "coalition_id": {"type": "string"},
          "rationale": {"type": "string", "maxLength": 500}
        }
      }
    },
    {
      "tool_id": "propose_leave_coalition",
      "category": "group",
      "description": "Propose leaving a coalition.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["coalition_id"],
        "properties": {
          "coalition_id": {"type": "string"},
          "rationale": {"type": "string", "maxLength": 500}
        }
      }
    },
    {
      "tool_id": "self_rate_emotions",
      "category": "state_report",
      "description": "Self-report current emotional state. Keys must be from emotions.json; values in [0,10].",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["emotions"],
        "properties": {
          "emotions": {
            "type": "object",
            "additionalProperties": {"type": "number", "minimum": 0, "maximum": 10}
          }
        }
      }
    },
    {
      "tool_id": "self_rate_issue_stance",
      "category": "state_report",
      "description": "Self-report stance on each issue axis. Keys must be from issue_stance_axes.json (default + scenario extensions); values in [-1,1].",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["issue_stance"],
        "properties": {
          "issue_stance": {
            "type": "object",
            "additionalProperties": {"type": "number", "minimum": -1, "maximum": 1}
          }
        }
      }
    },
    {
      "tool_id": "estimate_perceived_majority",
      "category": "state_report",
      "description": "Self-report what fraction of the visible audience the actor believes shares each stance. Used to drive spiral-of-silence dynamics.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["perceived_majority"],
        "properties": {
          "perceived_majority": {
            "type": "object",
            "description": "Map of stance_axis_key -> perceived agreeing fraction in [0,1].",
            "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
          }
        }
      }
    },
    {
      "tool_id": "estimate_willingness_to_speak",
      "category": "state_report",
      "description": "Self-report the actor's current willingness to speak publicly on the focal issue.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["willingness_to_speak"],
        "properties": {
          "willingness_to_speak": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    {
      "tool_id": "estimate_action_threshold",
      "category": "state_report",
      "description": "Self-report the threshold (peer participation, perceived efficacy, etc.) at which the actor would mobilize beyond expression into concrete action.",
      "json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mobilization_threshold"],
        "properties": {
          "mobilization_threshold": {"type": "number", "minimum": 0, "maximum": 1},
          "blocking_factor": {"type": "string", "enum": ["cost_fear", "low_efficacy", "low_peer_participation", "fatigue", "spiral_silence", "none"], "default": "none"}
        }
      }
    }
  ]
}
