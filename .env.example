# DO NOT COMMIT real keys — copy to .env and fill in real values
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
ZEP_API_KEY=z_REPLACE_ME

# Database / cache
DATABASE_URL=postgresql+asyncpg://worldfork:worldfork@localhost:5432/worldfork
DATABASE_URL_SYNC=postgresql+psycopg://worldfork:worldfork@localhost:5432/worldfork
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Run ledger
RUN_ROOT=/data/runs

# Provider defaults
DEFAULT_MODEL=openai/gpt-5.4
FALLBACK_MODEL=openai/gpt-5.4-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_TITLE=WorldFork

# CORS
NEXT_ORIGIN=http://localhost:3000

# Frontend (consumed by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Misc
LOG_LEVEL=INFO
ENVIRONMENT=development
