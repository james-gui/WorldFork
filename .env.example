# DO NOT COMMIT real keys — copy to .env and fill in real values
OPENROUTER_API_KEY=
ZEP_ENABLED=false
ZEP_API_KEY=

# Database / cache
DATABASE_URL=postgresql+asyncpg://worldfork:worldfork@localhost:5433/worldfork
DATABASE_URL_SYNC=postgresql+psycopg://worldfork:worldfork@localhost:5433/worldfork
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Run ledger
RUN_ROOT=/data/runs

# Provider defaults
DEFAULT_MODEL=deepseek/deepseek-v3.2
FALLBACK_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3003
OPENROUTER_TITLE=WorldFork

# CORS
NEXT_ORIGIN=http://localhost:3003

# Frontend (consumed by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8003
NEXT_PUBLIC_WS_URL=ws://localhost:8003

# Misc
LOG_LEVEL=INFO
ENVIRONMENT=development
